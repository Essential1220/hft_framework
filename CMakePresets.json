{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 16,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "vs2022-x64",
      "displayName": "Visual Studio 2022 x64",
      "description": "Use Visual Studio 2022 generator for x64 builds.",
      "generator": "Visual Studio 17 2022",
      "architecture": "x64",
      "binaryDir": "${sourceDir}/build_vs2022",
      "cacheVariables": {
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/dist",
        "ENABLE_PYTHON": "ON",
        "ENABLE_QT_DESKTOP": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2022-debug",
      "displayName": "Build Debug",
      "configurePreset": "vs2022-x64",
      "configuration": "Debug"
    },
    {
      "name": "vs2022-release",
      "displayName": "Build Release",
      "configurePreset": "vs2022-x64",
      "configuration": "Release"
    }
  ]
}
